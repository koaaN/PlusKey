<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/app_name"
        app:titleCentered="false"
        android:background="@android:color/transparent"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <!-- Glowing pill stage. We layer:
         (1) the GlowingPillView as a soft halo (RenderEffect blur),
         (2) a sharp inner pill (sibling FrameLayout with stroked drawable),
         (3) icon + label + description stacked centred.
         The whole stage is centered and grows to fill available height. -->
    <FrameLayout
        android:id="@+id/pill_stage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="36dp">

        <com.oplus.pluskey.ui.GlowingPillView
            android:id="@+id/pill_halo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <View
            android:id="@+id/pill_sharp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="28dp"
            android:background="@drawable/pill_sharp_outline"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp">

            <ImageView
                android:id="@+id/action_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@null"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/action_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:gravity="center"/>

            <TextView
                android:id="@+id/action_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="14sp"
                android:gravity="center"
                android:alpha="0.65"
                android:textColor="?attr/colorOnSurface"/>

            <Spinner
                android:id="@+id/camera_mode_picker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Action chip row, scrollable horizontally. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/action_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <!-- "In use" / "Selected" indicator pill. -->
    <TextView
        android:id="@+id/in_use_pill"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="36dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/in_use"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:background="@drawable/bg_in_use_pill"/>
</LinearLayout>
